# Copy this file to services/backend/.local/final-resources.env.
# Fill the copy only. Do not commit filled resources.

# Backend-only provider keys.
MESHY_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

# Print handoff. Use local for no-key demos, or treatstock for live quote handoff.
PRINT_PROVIDER=local
TREATSTOCK_API_KEY=
TREATSTOCK_API_BASE_URL=https://www.treatstock.com
SCULPTEO_API_KEY=

# iPhone deploy handoff.
DEVELOPMENT_TEAM=
PRODUCT_BUNDLE_IDENTIFIER=com.example.personalmythforge
PMF_BACKEND_BASE_URL=http://192.168.1.10:8080
PMF_FINAL_LAUNCH_MODE=local

# Optional local storage overrides.
CAPTURE_STORAGE_DIR=
MYTH_SESSION_STORAGE_DIR=
